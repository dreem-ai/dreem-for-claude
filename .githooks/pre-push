#!/usr/bin/env bash
# Blocks `git push` if gitleaks finds a likely secret in the commits being pushed.
# Enable once per clone: git config core.hooksPath .githooks

set -euo pipefail

ZERO_SHA="0000000000000000000000000000000000000000"

if ! command -v gitleaks >/dev/null 2>&1; then
  echo "pre-push: gitleaks not installed - secret scan SKIPPED." >&2
  echo "pre-push: install it (brew install gitleaks) to actually enforce this check." >&2
  exit 0
fi

failed=0

while read -r local_ref local_sha remote_ref remote_sha; do
  # Deleting a ref - nothing to scan.
  if [ "$local_sha" = "$ZERO_SHA" ]; then
    continue
  fi

  if [ "$remote_sha" = "$ZERO_SHA" ]; then
    # New branch on the remote: scan everything reachable from the tip being pushed.
    range="$local_sha"
  else
    # Existing branch: scan only the commits new since the remote's current tip.
    range="$remote_sha..$local_sha"
  fi

  echo "pre-push: scanning $local_ref ($range) for secrets..."
  if ! gitleaks git . --log-opts="$range" --redact --no-banner; then
    echo "pre-push: BLOCKED - gitleaks found a likely secret in $local_ref." >&2
    echo "pre-push: fix it, or if it's a real false positive add a scoped rule to .gitleaks.toml, then push again." >&2
    echo "pre-push: never bypass this with --no-verify - investigate the finding instead." >&2
    failed=1
  fi
done

exit $failed
